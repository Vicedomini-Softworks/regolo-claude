#!/usr/bin/env python3
"""
Regolo CLI wrapper - Launch Claude Code with Regolo.ai models

Usage:
    regolo claude --model=qwen3.5:122B
    regolo claude --model=qwen3.5:72B
    regolo list
    regolo login
    regolo logout
"""

import argparse
import json
import os
import subprocess
import sys

REGOLO_BASE_URL = "https://api.regolo.ai"
REGOLO_API_KEY = os.environ.get("REGOLO_API_KEY", "")
AUTH_FILE = os.path.expanduser("~/.regolo/auth.json")


def ensure_auth_dir():
    """Ensure the auth directory exists."""
    auth_dir = os.path.dirname(AUTH_FILE)
    if not os.path.exists(auth_dir):
        os.makedirs(auth_dir, mode=0o700)


def get_api_key_from_storage():
    """Retrieve API key from auth.json file."""
    try:
        if os.path.exists(AUTH_FILE):
            with open(AUTH_FILE, 'r') as f:
                data = json.load(f)
                return data.get('api_key')
    except (json.JSONDecodeError, IOError):
        pass
    return None


def save_api_key_to_storage(api_key: str):
    """Save API key to auth.json file."""
    try:
        ensure_auth_dir()
        with open(AUTH_FILE, 'w') as f:
            json.dump({'api_key': api_key}, f)
        os.chmod(AUTH_FILE, 0o600)
        return True
    except Exception as e:
        print(f"Error saving API key: {e}", file=sys.stderr)
        return False


def delete_api_key_from_storage():
    """Delete API key from auth.json file."""
    try:
        if os.path.exists(AUTH_FILE):
            os.remove(AUTH_FILE)
    except OSError:
        pass


def get_masked_input(prompt: str) -> str:
    """Get input with masked characters (like password input)."""
    try:
        import getpass
        return getpass.getpass(prompt)
    except Exception:
        print("\nNote: masked input not supported on this terminal.")
        return input(prompt)


def check_api_key():
    """Check if REGOLO_API_KEY is set, either from env or key vault."""
    if REGOLO_API_KEY:
        return REGOLO_API_KEY
    
    stored_key = get_api_key_from_storage()
    if stored_key:
        return stored_key
    
    print(
        "Error: REGOLO_API_KEY not found.",
        file=sys.stderr
    )
    print("Run 'regolo login' to set your API key.", file=sys.stderr)
    sys.exit(1)


def login():
    """Login and store API key securely in ~/.regolo/auth.json."""
    print("Regolo.ai API Login")
    print("-" * 40)
    
    api_key = get_masked_input("Enter your Regolo API key: ")
    
    if not api_key or len(api_key.strip()) == 0:
        print("Error: API key cannot be empty.", file=sys.stderr)
        sys.exit(1)
    
    api_key = api_key.strip()
    
    if save_api_key_to_storage(api_key):
        print(f"\n✓ API key saved successfully!")
        print(f"Your key is stored securely in: {AUTH_FILE}")
    else:
        print("\n⚠ API key not saved. You can set it via environment variable:")
        print("  export REGOLO_API_KEY=your_api_key")


def logout():
    """Logout and remove API key from OS key vault."""
    delete_api_key_from_storage()
    print("✓ API key removed from secure storage.")
    print("You are now logged out.")


def list_models():
    """List available Regolo models from the API."""
    api_key = check_api_key()
    
    try:
        import urllib.request
        req = urllib.request.Request(
            f"{REGOLO_BASE_URL}/models",
            headers={"Authorization": f"Bearer {api_key}"}
        )
        with urllib.request.urlopen(req) as response:
            data = json.loads(response.read().decode())
            print("Available Regolo models:")
            for model in data.get("data", []):
                model_id = model.get("id", "unknown")
                print(f"  {model_id}")
    except Exception as e:
        print(f"Error fetching models from API: {e}", file=sys.stderr)
        print("Please ensure you're logged in with 'regolo login'", file=sys.stderr)


PROXY_PORT = 30123


def find_existing_proxy():
    """Check if a proxy is already running and find its port."""
    import subprocess
    import re
    
    try:
        result = subprocess.run(
            ["lsof", "-i", "-P", "-n"],
            capture_output=True,
            text=True,
            timeout=5
        )
        
        for line in result.stdout.split('\n'):
            if 'router_server.py' in line or 'regolo-proxy' in line:
                match = re.search(r'TCP\s+\*:(\d+)', line)
                if match:
                    port = int(match.group(1))
                    try:
                        req = urllib.request.Request(f"http://localhost:{port}/health")
                        with urllib.request.urlopen(req, timeout=1) as response:
                            if response.status == 200:
                                print(f"Found existing proxy on port {port}")
                                return port
                    except:
                        pass
    except:
        pass
    return None


def start_proxy_background():
    """Start proxy server in background and wait for it to be ready."""
    import time
    import urllib.error
    import urllib.request
    import re
    
    actual_port = find_existing_proxy()
    if actual_port:
        print(f"Found existing proxy server on port {actual_port}")
        return None, actual_port
    
    print(f"Starting proxy server...")
    
    import shutil
    python_cmd = shutil.which("python3") or sys.executable
    
    proxy_proc = subprocess.Popen(
        [python_cmd, "router_server.py"],
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
        bufsize=1
    )
    
    actual_port = None
    poll_count = 0
    
    while poll_count < 100:
        line = proxy_proc.stdout.readline()
        if line:
            print(line.strip(), flush=True)
            match = re.search(r'on port (\d+)', line)
            if match:
                actual_port = int(match.group(1))
                print(f"Proxy server ready at http://localhost:{actual_port}", flush=True)
                return proxy_proc, actual_port
        
        poll_count += 1
        
        if proxy_proc.poll() is not None:
            break
        
        time.sleep(0.1)
    
    if not actual_port:
        print("Warning: Proxy server may not have started correctly", file=sys.stderr)
    return proxy_proc, actual_port or PROXY_PORT


def start_proxy():
    """Start the proxy server in foreground."""
    print("Starting proxy server...")
    print("Make sure aiohttp is installed: pip install aiohttp")
    print()
    
    try:
        import shutil
        python_cmd = shutil.which("python3") or sys.executable
        subprocess.run(
            [python_cmd, "router_server.py"],
            check=True
        )
    except KeyboardInterrupt:
        print("\nProxy server stopped.")
    except FileNotFoundError:
        print("Error: router_server.py not found.", file=sys.stderr)
        sys.exit(1)


def launch_claude(model: str, use_proxy: bool = True):
    """Launch Claude Code with the specified Regolo model."""
    api_key = check_api_key()

    env = os.environ.copy()
    env["ANTHROPIC_API_KEY"] = api_key
    env["ANTHROPIC_MODEL"] = model

    proxy_proc = None
    actual_port = PROXY_PORT
    if use_proxy:
        proxy_proc, actual_port = start_proxy_background()
        env["ANTHROPIC_BASE_URL"] = f"http://localhost:{actual_port}"
        print(f"Launching Claude Code with Regolo model: {model}")
        print(f"Proxy server: http://localhost:{actual_port}")
        print(f"Model: {model}")
        print("-" * 50)
    else:
        env["ANTHROPIC_BASE_URL"] = REGOLO_BASE_URL
        print(f"Launching Claude Code with Regolo model: {model}")
        print(f"API endpoint: {REGOLO_BASE_URL}")
        print("-" * 50)

    try:
        subprocess.run(["claude"], env=env, check=True)
    except FileNotFoundError:
        print("Error: 'claude' command not found.", file=sys.stderr)
        print("Please install Claude Code: npm install -g @anthropic-ai/claude-code", file=sys.stderr)
        sys.exit(1)
    except KeyboardInterrupt:
        print("\nExiting...")
        if proxy_proc:
            proxy_proc.terminate()
            proxy_proc.wait()
        sys.exit(0)
    finally:
        if proxy_proc:
            proxy_proc.terminate()


def main():
    parser = argparse.ArgumentParser(
        description="Launch Claude Code with Regolo.ai models",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
    regolo login
    regolo claude --model=qwen3.5:122B
    regolo claude --model=qwen3:8B
    regolo list
    regolo proxy          # Start proxy server for messages API compatibility
    regolo logout

Environment:
    REGOLO_API_KEY  Override stored API key (optional)
    PORT            Proxy server port (default: 8789)
        """
    )

    subparsers = parser.add_subparsers(dest="command", help="Available commands")

    # Claude subcommand
    claude_parser = subparsers.add_parser("claude", help="Launch Claude Code with a Regolo model")
    claude_parser.add_argument(
        "--model", "-m",
        type=str,
        default="brick-v1-beta",
        help="Model to use (default: brick-v1-beta)"
    )

    # List subcommand
    subparsers.add_parser("list", help="List available models")

    # Login subcommand
    subparsers.add_parser("login", help="Login and store API key securely")

    # Logout subcommand
    subparsers.add_parser("logout", help="Logout and remove API key")

    # Proxy subcommand
    proxy_parser = subparsers.add_parser("proxy", help="Start the messages proxy server")
    proxy_parser.add_argument(
        "--port", "-p",
        type=int,
        default=8789,
        help="Port to run the proxy on (default: 8789)"
    )

    args = parser.parse_args()

    if args.command == "list":
        list_models()
    elif args.command == "claude":
        launch_claude(args.model)
    elif args.command == "login":
        login()
    elif args.command == "logout":
        logout()
    elif args.command == "proxy":
        os.environ["PORT"] = str(args.port)
        start_proxy()
    else:
        parser.print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
